# Copy to .env for local deploy builds, or set these in your hosting dashboard.

# Supabase project URL (Settings → API)
SUPABASE_URL=https://your-project.supabase.co

# Public anon / publishable key only — never the service-role key
SUPABASE_ANON_KEY=your-anon-key

# Nova organisation UUID from supabase-schema.sql
NOVA_ORGANISATION_ID=00000000-0000-0000-0000-000000000001

# Force Supabase provider when URL and key are set (optional; auto-detected)
NOVA_PROVIDER=supabase
